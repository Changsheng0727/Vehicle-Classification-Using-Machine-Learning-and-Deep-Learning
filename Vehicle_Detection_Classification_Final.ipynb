   "id": "resnet-model",
   "metadata": {},
   "source": [
    "## 4. ResNet50分类模型"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "build-resnet",
   "metadata": {},
   "outputs": [],
   "source": [
    "class VehicleClassifier:\n",
    "    \"\"\"基于ResNet50的车辆分类器\"\"\"\n",
    "    \n",
    "    def __init__(self, num_classes=4, input_shape=(224, 224, 3)):\n",
    "        \"\"\"初始化分类器\"\"